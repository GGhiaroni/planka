# =============================================================================
# Production environment variables
# =============================================================================
# Copy this file to `.env` and fill all values before running:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# These domains MUST already point to the server's public IP via DNS A records.
# Caddy will automatically provision Let's Encrypt TLS certs on first request.
PLANKA_DOMAIN=app.seudominio.com.br
FORM_DOMAIN=formularios.seudominio.com.br
LETSENCRYPT_EMAIL=admin@seudominio.com.br

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=GERAR_SENHA_FORTE_AQUI

# -----------------------------------------------------------------------------
# Planka
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 64
SECRET_KEY=GERAR_HEX_64_BYTES_AQUI

ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=GERAR_SENHA_FORTE_AQUI
ADMIN_NAME=Administrador
ADMIN_USERNAME=admin

# -----------------------------------------------------------------------------
# Ticket Form Service
# -----------------------------------------------------------------------------
# Use the same Planka admin credentials (or create a dedicated bot user
# with editor access on both boards and put those credentials here).
PLANKA_FORM_EMAIL=admin@seudominio.com.br
PLANKA_FORM_PASSWORD=GERAR_SENHA_FORTE_AQUI

# -----------------------------------------------------------------------------
# Board IDs — fill in AFTER the first deploy.
# -----------------------------------------------------------------------------
# Steps to obtain:
#   1. Run `docker compose ... up -d planka postgres caddy` (without ticket-form)
#   2. Log into Planka, create the projects/boards/lists/labels.
#   3. From the browser DevTools → Network → click any card → copy the listId
#      from the response JSON.
#   4. Fill values below and run `docker compose ... up -d ticket-form`.
#
# Target list for "Pedido de Artes" form (Design board)
PLANKA_LIST_ID=

# Target list for "Chamado Técnico" form (Chamados Técnicos board)
PLANKA_CHAMADOS_LIST_ID=

# Priority label IDs from the Chamados Técnicos board.
# Format: "NAME:id,NAME:id,..."
PRIORITY_LABELS=BAIXA PRIORIDADE:,MÉDIA GRAVIDADE:,URGÊNCIA:,EM TRATAMENTO:,ATUALIZAÇÃO DO TRATAMENTO:,PENDÊNCIAS DE INSTALAÇÃO:,EM ESPERA:,MÁXIMA PRIORIDADE:

# Reasons shown in the simple `/api/submit` form (legacy — kept for compatibility)
CONTACT_REASONS=Manutenção,Financeiro,Troca de Arte
